<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Danh sách sản phẩm</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      .modal {
        display: none;
        background: rgba(0, 0, 0, 0.5);
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }
      .modal-dialog {
        margin: 10% auto;
      }
    </style>
  </head>
  <body class="p-3">
    <a href="/products/add" class="btn btn-sm btn-primary mb-3"
      >+ Thêm sản phẩm</a
    >

    <table class="table table-hover table-bordered">
      <thead class="table-dark">
        <tr>
          <th>Tên</th>
          <th>Mô tả</th>
          <th>Danh mục</th>
          <th>Hình ảnh</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(p => { %>
        <tr id="product-<%= p._id %>">
          <td class="name"><%= p.name %></td>
          <td class="description"><%= p.description %></td>
          <td class="category">
            <%= p.category ? p.category.name : "Chưa có" %>
          </td>
          <td class="images">
            <% p.images.forEach(img => { %>
            <img src="<%= img %>" alt="" width="50" class="me-2 rounded" />
            <% }) %>
          </td>
          <td>
            <a href="/products/<%= p._id %>/variants" class="btn btn-info"
              >Biến thể</a
            >
            <button
              class="btn btn-sm btn-warning"
              onclick="editProduct('<%= p._id %>')"
            >
              Sửa
            </button>
            <button
              class="btn btn-sm <%= p.isHidden ? 'btn-success' : 'btn-secondary' %>"
              onclick="toggleHide('<%= p._id %>')"
            >
              <%= p.isHidden ? 'Hiện 👁' : 'Ẩn 👁‍🗨' %>
            </button>
            <button
              class="btn btn-sm btn-danger"
              onclick="deleteProduct('<%= p._id %>')"
            >
              Xóa
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Modal sửa sản phẩm -->
    <div class="modal" id="editModal">
      <div class="modal-dialog">
        <div class="modal-content">
          <form id="editForm" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Sửa sản phẩm</h5>
              <button
                type="button"
                class="btn-close"
                onclick="closeModal()"
              ></button>
            </div>
            <div class="modal-body">
              <input
                type="text"
                name="name"
                class="form-control mb-2"
                placeholder="Tên sản phẩm"
                required
              />
              <textarea
                name="description"
                class="form-control mb-2"
                placeholder="Mô tả"
              ></textarea>
              <select name="category" class="form-control mb-2">
                <option value="">-- Chọn danh mục --</option>
                <% categories.forEach(cat => { %>
                <option value="<%= cat._id %>"><%= cat.name %></option>
                <% }) %>
              </select>
              <input
                type="file"
                name="images"
                class="form-control mb-2"
                multiple
              />
            </div>
            <div class="modal-footer">
              <button
                type="button"
                class="btn btn-secondary"
                onclick="closeModal()"
              >
                Đóng
              </button>
              <button type="submit" class="btn btn-primary">
                Lưu thay đổi
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      function closeModal() {
        document.querySelector("#editModal").style.display = "none";
      }

      async function toggleHide(productId) {
        try {
          const res = await fetch(`/api/products/${productId}/hide`, {
            method: "PATCH",
          });
          const data = await res.json();
          if (res.ok) {
            const btn = document.querySelector(
              `#product-${productId} button:nth-child(2)`
            );
            if (data.product.isHidden) {
              btn.textContent = "Hiện 👁";
              btn.classList.remove("btn-secondary");
              btn.classList.add("btn-success");
            } else {
              btn.textContent = "Ẩn 👁‍🗨";
              btn.classList.remove("btn-success");
              btn.classList.add("btn-secondary");
            }
            alert(data.message);
          } else alert(data.error);
        } catch (err) {
          alert("Có lỗi: " + err.message);
        }
      }

      async function deleteProduct(productId) {
        if (!confirm("Bạn có chắc muốn xóa sản phẩm này?")) return;
        try {
          const res = await fetch(`/api/products/${productId}`, {
            method: "DELETE",
          });
          const data = await res.json();
          if (res.ok) {
            alert(data.message);
            const row = document.getElementById(`product-${productId}`);
            if (row) row.remove();
          } else {
            alert(data.error || "Xóa thất bại");
          }
        } catch (err) {
          console.error(err);
          alert("Có lỗi xảy ra khi xóa sản phẩm");
        }
      }

      async function editProduct(productId) {
        try {
          const res = await fetch(`/api/products/${productId}`);
          const product = await res.json();

          const form = document.querySelector("#editForm");
          form.name.value = product.name;
          form.description.value = product.description;
          form.category.value = product.category?._id || "";

          document.querySelector("#editModal").style.display = "block";

          form.onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData(form);

            const resUpdate = await fetch(`/api/products/${productId}`, {
              method: "PUT",
              body: formData,
            });
            const updated = await resUpdate.json();
            if (resUpdate.ok) {
              const row = document.querySelector(`#product-${productId}`);
              row.querySelector(".name").textContent = updated.name;
              row.querySelector(".description").textContent =
                updated.description;
              row.querySelector(".category").textContent =
                updated.category?.name || "Chưa có";

              if (updated.images && updated.images.length) {
                row.querySelector(".images").innerHTML = "";
                updated.images.forEach((img) => {
                  const imageElem = document.createElement("img");
                  imageElem.src = img;
                  imageElem.width = 50;
                  imageElem.className = "me-2 rounded";
                  row.querySelector(".images").appendChild(imageElem);
                });
              }

              closeModal();
              alert("Cập nhật thành công!");
            } else alert(updated.error);
          };
        } catch (err) {
          alert("Có lỗi: " + err.message);
        }
      }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
