<div
  class="d-flex justify-content-center align-items-center vh-100"
  style="background: var(--bg)"
>
  <div class="card shadow-lg p-4" style="width: 400px">
    <h3 class="text-center mb-3">Đăng ký tài khoản</h3>
    <form id="registerForm">
      <div class="mb-3">
        <label>Họ tên</label>
        <input
          type="text"
          id="name"
          class="form-control"
          placeholder="Nhập họ tên"
          required
        />
      </div>
      <div class="mb-3">
        <label>Email</label>
        <input
          type="email"
          id="email"
          class="form-control"
          placeholder="Nhập email"
          required
        />
      </div>
      <div class="mb-3">
        <label>Mật khẩu</label>
        <input
          type="password"
          id="password"
          class="form-control"
          placeholder="Nhập mật khẩu"
          required
        />
      </div>
      <div class="mb-3">
        <label>Xác nhận mật khẩu</label>
        <input
          type="password"
          id="confirmPassword"
          class="form-control"
          placeholder="Nhập lại mật khẩu"
          required
        />
      </div>
      <button type="submit" class="btn btn-success w-100">Đăng ký</button>
    </form>
    <div id="message" class="mt-3 text-center"></div>
    <hr />
    <p class="text-center mb-0">
      Đã có tài khoản? <a href="/login">Đăng nhập</a>
    </p>
  </div>
</div>

<script>
  document
    .getElementById("registerForm")
    .addEventListener("submit", async (e) => {
      e.preventDefault();

      const name = document.getElementById("name").value.trim();
      const email = document.getElementById("email").value.trim();
      const password = document.getElementById("password").value;
      const confirmPassword = document.getElementById("confirmPassword").value;
      const messageDiv = document.getElementById("message");

      if (password !== confirmPassword) {
        messageDiv.innerHTML =
          '<div class="text-danger">Mật khẩu không khớp!</div>';
        return;
      }

      try {
        const response = await fetch("/api/auth/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, email, password, role: "admin" }),
        });

        const data = await response.json();

        if (response.ok) {
          messageDiv.innerHTML =
            '<div class="text-success">Đăng ký thành công! Đang chuyển hướng...</div>';
          setTimeout(() => {
            window.location.href = "/login";
          }, 1500);
        } else {
          messageDiv.innerHTML = `<div class="text-danger">${data.message}</div>`;
        }
      } catch (err) {
        messageDiv.innerHTML =
          '<div class="text-danger">Lỗi kết nối server!</div>';
      }
    });
</script>
