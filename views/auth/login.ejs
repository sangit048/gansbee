<div
  class="d-flex justify-content-center align-items-center vh-100"
  style="background: var(--bg)"
>
  <div class="card shadow-lg p-4" style="width: 400px">
    <h3 class="text-center mb-3">Đăng nhập Admin</h3>
    <form id="loginForm">
      <div class="mb-3">
        <label>Email</label>
        <input
          type="email"
          id="email"
          class="form-control"
          placeholder="Nhập email"
          required
        />
      </div>
      <div class="mb-3">
        <label>Mật khẩu</label>
        <input
          type="password"
          id="password"
          class="form-control"
          placeholder="Nhập mật khẩu"
          required
        />
      </div>
      <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
    </form>
    <div id="message" class="mt-3 text-center"></div>
  </div>
</div>

<script>
  // Trong file login.ejs hoặc file JavaScript liên quan
  document.getElementById("loginForm").addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    const response = await fetch("/api/auth/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password }),
    });

    const data = await response.json();
    const messageDiv = document.getElementById("message");

    if (response.ok) {
      if (data.user && data.user.role === "admin") {
        localStorage.setItem("token", data.token);
        // Tải lại trang /dashboard với token trong header
        const dashboardResponse = await fetch("/dashboard", {
          method: "GET",
          headers: {
            Authorization: `Bearer ${data.token}`,
          },
        });
        if (dashboardResponse.ok) {
          window.location.href = "/dashboard";
        } else {
          const errorData = await dashboardResponse.json();
          messageDiv.innerHTML = `<div class="text-danger">${errorData.message}</div>`;
        }
      } else {
        messageDiv.innerHTML =
          '<div class="text-danger">Bạn không phải admin!</div>';
      }
    } else {
      messageDiv.innerHTML = `<div class="text-danger">${data.message}</div>`;
    }
  });
</script>
